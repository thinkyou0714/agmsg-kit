diff --git a/scripts/send.sh b/scripts/send.sh
index c21dd8d..81dce19 100755
--- a/scripts/send.sh
+++ b/scripts/send.sh
@@ -8,6 +8,27 @@ FROM="${2:?Missing from agent}"
 TO="${3:?Missing to agent}"
 BODY="${4:?Missing message body}"
 
+# Cap body size: runaway guard + avoid an obscure "Argument list too long" crash
+# (send passes the whole INSERT, incl. body, as one sqlite3 arg -> overflows the
+# OS command line, ~32K on Windows). Measure BYTES (not chars) so multibyte UTF-8
+# is bounded correctly. An invalid AGMSG_MAX_BODY_BYTES falls back to the
+# protective default (fail safe). REJECT, not truncate. agmsg-kit.
+_AGMSG_MAX_BODY="${AGMSG_MAX_BODY_BYTES:-}"
+case "$_AGMSG_MAX_BODY" in
+  ''|*[!0-9]*)
+    case "$(uname -s 2>/dev/null)" in
+      MINGW*|MSYS*|CYGWIN*) _AGMSG_MAX_BODY=16000 ;;
+      *) _AGMSG_MAX_BODY=65536 ;;
+    esac ;;
+esac
+if [ "$_AGMSG_MAX_BODY" -gt 0 ]; then
+  _agmsg_body_bytes=$(printf %s "$BODY" | wc -c | tr -d " ")
+  if [ "$_agmsg_body_bytes" -gt "$_AGMSG_MAX_BODY" ]; then
+    echo "agmsg: message body too large: $_agmsg_body_bytes bytes (limit $_AGMSG_MAX_BODY); set AGMSG_MAX_BODY_BYTES to override (0 disables). Large payloads belong in a file referenced by path." >&2
+    exit 1
+  fi
+fi
+
 SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
 source "$SCRIPT_DIR/lib/storage.sh"
 DB="$(agmsg_db_path)"
