# agmsg-kit parameters. Copy to .env (gitignored) and set your values.
# install.sh resolves: command-line flags > .env > these defaults.
# The defaults are intentionally generic so the public repo ships no personal
# config — your team name, agent names, and collaboration path live only in
# your local .env.

# Skill/command folder name. Claude Code: /<cmd>, Codex: $<cmd>.
AGMSG_CMD=agmsg

# Team + the two agent identities to register on this machine.
AGMSG_TEAM=team
AGMSG_CC=cc
AGMSG_CO=codex

# Collaboration repo the agents coordinate in. Defaults to $PWD at install time.
#AGMSG_PROJECT=/path/to/your/collab/repo

# Pinned upstream commit (fujibee/agmsg v1.1.1). Bump deliberately — see
# VENDORED.md and `make refresh-patches`.
AGMSG_PIN=b4492e2019a140938292b7684bd3bad23c2774f5
#AGMSG_UPSTREAM=https://github.com/fujibee/agmsg.git

# Optional: append redacted JSON on install failure to this sink (off by default).
# Integrates with a personal observability log; secrets are redacted.
#AGMSG_FAILURE_LOG=/c/Users/you/.claude/failures.jsonl

# Optional: max message body size before send.sh rejects (runaway + ARG_MAX guard).
# Default 16000 on Windows (cmdline limit), 65536 elsewhere; 0 disables.
#AGMSG_MAX_BODY_BYTES=65536
